<?xml version="1.0" encoding="UTF-8"?>
<!--
  Maven Site descriptor — customises the navigation menu generated by `mvn site`.

  Why this file exists:
    dependency-check-maven 12.x throws AbstractMethodError when declared in
    <reporting> (it no longer implements the Maven reporting API). The HTML
    report is therefore generated during the verify phase and copied to
    target/site/ by maven-antrun-plugin (post-site execution in pom.xml).
    This descriptor adds the manual link to the site navigation so the report
    is reachable from the Maven site's left menu.
-->
<project xmlns="http://maven.apache.org/DECORATION/1.8.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/DECORATION/1.8.0
                             https://maven.apache.org/xsd/decoration-1.8.0.xsd">

    <!--
      Explicit skin declaration — required since maven-pmd-plugin 3.25+ upgraded
      to Doxia 2.0 which throws "skin cannot be null" when the pmd goal runs as a
      <build> execution (our case: pmd-analyze during verify).
      Bug: https://issues.apache.org/jira/browse/MPMD-403
    -->
    <skin>
        <groupId>org.apache.maven.skins</groupId>
        <artifactId>maven-fluido-skin</artifactId>
        <version>2.0.0-M11</version>
    </skin>

    <body>
        <menu name="Security">
            <item name="OWASP CVE Scan" href="dependency-check-report.html"/>
        </menu>

        <!-- Inherit all standard menus (Project Info, Project Reports) -->
        <menu ref="reports"/>
    </body>
</project>
