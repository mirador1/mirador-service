# Template for local environment configuration.
# Copy this file to .env (which is git-ignored) and fill in your values.
# Never commit secrets — use a secrets manager (HashiCorp Vault, AWS SSM, etc.) in production.
#
# ⚠️  .env and .env.example MUST have the same KEYS (values may differ).
#     When adding or removing a variable, update both files together.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost        # hostname visible from the app (localhost when running outside Compose)
DB_PORT=5432             # default PostgreSQL port
DB_NAME=customer-service # database name — must match V1__init.sql
DB_USER=demo             # superuser for local dev only — use a restricted role in production
DB_PASSWORD=demo         # local dev only — use a secrets manager (Vault, AWS SSM) in production

# ── Application ───────────────────────────────────────────────────────────────
SERVER_PORT=8080         # Spring Boot embedded Tomcat port
APP_NAME=customer-service # used as the Docker image name and Spring app name
IMAGE_TAG=latest         # Docker image tag pushed to the registry (override with a SHA for deploys)

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_PORT=9092          # Kafka broker port (KRaft mode, no ZooKeeper)

# ── Security ──────────────────────────────────────────────────────────────────
API_KEY=demo-api-key-2026 # X-API-Key header for M2M auth — use a secrets manager in production

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318   # OTLP collector for Tempo/Loki/Mimir (LGTM stack)

# ── GitLab Observability (ADR-0054 — optional 2nd OTLP sink) ──────────────────
# Enables dual-export of traces/metrics/logs to GitLab's managed
# Observability UI (free tier — unlimited). Reviewers see telemetry
# directly in the group sidebar without cloning the repo.
#
# Setup (one-time, ~5 min):
#  1. https://gitlab.com/groups/mirador1/-/observability/setup — enable
#  2. Copy the exact endpoint shown in the UI (not the placeholder below)
#  3. Generate a group access token at
#     https://gitlab.com/groups/mirador1/-/settings/access_tokens
#     with scopes: read_observability + write_observability
#  4. Export BOTH vars before `./run.sh obs` / demo-up
#  5. Uncomment the `otlphttp/*-gitlab` exporters in
#     infra/observability/otelcol-override.yaml
#
# Left commented by default — unset means the Collector's local-only
# pipeline keeps working (no GitLab egress).
# GITLAB_OBSERVABILITY_ENDPOINT=https://observability.gitlab.com/v3/<group-id>/otlp/v1
# GITLAB_OBSERVABILITY_TOKEN=glat-your-group-access-token

# ── SonarCloud ────────────────────────────────────────────────────────────────
# Generate at https://sonarcloud.io/account/security → Generate Token.
# Used by `./run.sh sonar` and by the SonarCloud CI job when run locally.
SONAR_TOKEN=your-sonarcloud-token


# ── OVH Cloud (canonical 2nd K8s target per ADR-0053) ─────────────────────────
# Generate the 3 API tokens at https://eu.api.ovh.com/createToken/ with
# narrow scope: GET/POST/PUT/DELETE on /cloud/project/* only.
# Validity: 0 (= unlimited; rotate manually every 6 months — set a calendar
# reminder). NEVER commit real values; bin/cluster/ovh/up.sh expects them
# in the shell environment, not in this file.
OVH_APPLICATION_KEY=your-ovh-application-key
OVH_APPLICATION_SECRET=your-ovh-application-secret-shown-once
OVH_CONSUMER_KEY=your-ovh-consumer-key
# 32-char hex from https://www.ovh.com/manager/#/cloud/project/<HERE>
OVH_PROJECT_ID=00000000000000000000000000000000

# Optional overrides (defaults: GRA9 region — HDS-eligible — and mirador-prod cluster)
# OVH_REGION=GRA9
# OVH_CLUSTER_NAME=mirador-prod
