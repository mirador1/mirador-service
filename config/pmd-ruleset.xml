<?xml version="1.0"?>
<!--
  =============================================================================
  PMD ruleset for mirador-service  (PMD 7.20.0+ / maven-pmd-plugin 3.26.0)
  =============================================================================

  PMD Java has 8 rule categories; this file enables 7 of them and tunes
  noisy rules per category. The 8th — codestyle — is partly enabled with
  most cosmetic rules excluded because they clash with Spring Boot idioms
  and IDE auto-formatting.

      Category         : Enabled : Rationale
      bestpractices    :   yes   : general "don't shoot yourself in the foot"
      codestyle        : partial : only meaningful rules; style handled by IDE
      design           :   yes   : minus LawOfDemeter + LoosePackageCoupling
      documentation    : partial : Javadoc rules only on public API
      errorprone       :   yes   : bug patterns (highest signal/noise)
      multithreading   :   yes   : service IS concurrent, these matter
      performance      :   yes   : allocation, string building, etc.
      security         :   yes   : crypto, SQL, path traversal

  When adding an exclusion, always leave a one-line note with:
    - WHY the rule is excluded (false positive, conflict, noise)
    - WHEN to revisit (if applicable)

  All exclusions below follow that convention. Remove the exclusion if the
  rule's upstream implementation changes (PMD release notes are at
  https://pmd.github.io/pmd/pmd_release_notes.html).
  =============================================================================
-->
<ruleset name="mirador-rules"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

    <description>Mirador PMD ruleset — 7 categories enabled, Spring-aware exclusions</description>

    <!-- =========================================================================
         BEST PRACTICES — general-purpose rules
         https://pmd.github.io/pmd/pmd_rules_java_bestpractices.html
         ========================================================================= -->
    <rule ref="category/java/bestpractices.xml">
        <!-- Suppressed: JUnit5 + AssertJ project style uses single-line fluent asserts
             without explicit messages; the rule would flag every assertion in the
             ~120 test classes. Re-evaluate if we migrate assertion libraries. -->
        <exclude name="JUnitAssertionsShouldIncludeMessage"/>
        <!-- Suppressed: conflicts with Spring Boot @ConfigurationProperties and DTO
             records where a getter is an implementation detail of Jackson binding. -->
        <exclude name="JUnitTestContainsTooManyAsserts"/>
    </rule>

    <!-- =========================================================================
         CODE STYLE — naming, imports, formatting
         https://pmd.github.io/pmd/pmd_rules_java_codestyle.html

         Cosmetic formatting is handled by the IDE + spotless/google-java-format;
         enabling every codestyle rule would duplicate that and produce noise.
         Only NON-formatting rules are kept below (naming, unused, duplication).
         ========================================================================= -->
    <rule ref="category/java/codestyle.xml">
        <!-- Pure formatting — IDE's job (spotless + google-java-format). -->
        <exclude name="LineLengthCheck"/>
        <exclude name="AvoidFinalLocalVariable"/>
        <exclude name="LocalVariableCouldBeFinal"/>
        <exclude name="MethodArgumentCouldBeFinal"/>
        <exclude name="CommentDefaultAccessModifier"/>
        <!-- Braces on single-line if/else — modern Java style allows without. -->
        <exclude name="ControlStatementBraces"/>
        <!-- `var` is an intentional style choice for local variables with obvious RHS type. -->
        <exclude name="UseExplicitTypes"/>
        <!-- Clashes with Spring's conventional @Autowired constructor-only-field pattern. -->
        <exclude name="AtLeastOneConstructor"/>
        <!-- Short names — noisy on records and stream lambdas. -->
        <exclude name="ShortMethodName"/>
        <exclude name="ShortVariable"/>
        <exclude name="LongVariable"/>
        <!-- Multiple returns are idiomatic with modern Java switch-expressions. -->
        <exclude name="OnlyOneReturn"/>
        <!-- Redundant with Java 21+ pattern matching for switch. -->
        <exclude name="CallSuperInConstructor"/>
        <!-- Parentheses often improve readability in boolean exprs. -->
        <exclude name="UselessParentheses"/>
        <!-- Ternaries are fine when short; the rule flags harmless cases. -->
        <exclude name="ConfusingTernary"/>
    </rule>

    <!-- =========================================================================
         DESIGN — coupling, cohesion, complexity
         https://pmd.github.io/pmd/pmd_rules_java_design.html
         ========================================================================= -->
    <rule ref="category/java/design.xml">
        <!-- Known PMD issue on Java 25 with deep call chains (stack overflow during
             type resolution of generic bounds). Reassess when PMD 7.25+ ships with
             the fix from https://github.com/pmd/pmd/issues/5096 verified stable. -->
        <exclude name="LawOfDemeter"/>
        <!-- Flags every Spring package that spans multiple modules (controller +
             service + repo in com.mirador.customer). The design IS intentionally
             package-per-feature; this rule assumes package-per-layer. -->
        <exclude name="LoosePackageCoupling"/>
    </rule>

    <!-- =========================================================================
         DOCUMENTATION — Javadoc presence and quality
         https://pmd.github.io/pmd/pmd_rules_java_documentation.html

         We document public API thoroughly but don't require Javadoc on every
         private helper. Rules below are the conservative subset.
         ========================================================================= -->
    <rule ref="category/java/documentation.xml">
        <!-- Too strict — flags the one-line "// why" comments on private methods,
             which are our preferred style (see global CLAUDE.md). -->
        <exclude name="CommentRequired"/>
        <!-- Enforces a max line length in comments — purely cosmetic, IDE's job. -->
        <exclude name="CommentSize"/>
    </rule>

    <!-- =========================================================================
         ERROR-PRONE — bug patterns with very high signal/noise
         https://pmd.github.io/pmd/pmd_rules_java_errorprone.html
         ========================================================================= -->
    <rule ref="category/java/errorprone.xml">
        <!-- Fires on every record / DTO class that doesn't override equals().
             Java records auto-generate equals() so the check is redundant and
             creates hundreds of warnings for our many DTO records. -->
        <exclude name="MissingSerialVersionUID"/>
        <!-- Flags lombok @Data classes for the same auto-generated reason. -->
        <exclude name="BeanMembersShouldSerialize"/>
        <!-- Catching `Exception` is legitimate in top-level @ControllerAdvice and
             scheduled-task wrappers where we MUST not let an untyped failure
             escape to the framework. Rule can't distinguish those from bad catches. -->
        <exclude name="AvoidCatchingGenericException"/>
        <!-- Magic numbers inside if-conditions: noisy in switch-like dispatch code
             (e.g. HTTP status range checks). Use @SuppressWarnings per-case instead. -->
        <exclude name="AvoidLiteralsInIfCondition"/>
    </rule>

    <!-- =========================================================================
         MULTI-THREADING — concurrency bugs (race conditions, deadlocks, …)
         https://pmd.github.io/pmd/pmd_rules_java_multithreading.html

         Previously DISABLED — re-enabled 2026-04-16 because the service has
         scheduled jobs, Kafka consumers, and WebSocket handlers; concurrency
         bugs are worth catching early.
         ========================================================================= -->
    <rule ref="category/java/multithreading.xml">
        <!-- DoNotUseThreads conflicts with Spring's @Scheduled + @Async which
             are managed thread pools — the rule can't tell the difference
             between a naked `new Thread()` and a Spring-managed task. -->
        <exclude name="DoNotUseThreads"/>
        <!-- UseConcurrentHashMap is good practice but too broad — flags every
             read-only HashMap initialized at startup and never mutated. -->
        <exclude name="UseConcurrentHashMap"/>
    </rule>

    <!-- =========================================================================
         PERFORMANCE — allocation, string builders, collections
         https://pmd.github.io/pmd/pmd_rules_java_performance.html
         ========================================================================= -->
    <rule ref="category/java/performance.xml">
        <!-- Clashes with the IDE-generated toString() using "+" which is
             auto-converted to StringBuilder by javac. Modern JVMs handle it fine. -->
        <exclude name="AvoidInstantiatingObjectsInLoops"/>
        <!-- False positives in switch statements and lambdas where the "loop"
             is actually a collection stream that is NOT hot. -->
    </rule>

    <!-- =========================================================================
         SECURITY — crypto, SQL injection, path traversal, hardcoded credentials
         https://pmd.github.io/pmd/pmd_rules_java_security.html

         Previously DISABLED — re-enabled 2026-04-16. All rules kept; no known
         false positives on the current codebase. Any hardcoded credential
         intentionally added to test fixtures must be suppressed per-call-site
         with a dated @SuppressWarnings("PMD.HardCodedCryptoKey") + rationale.
         ========================================================================= -->
    <rule ref="category/java/security.xml"/>

</ruleset>
