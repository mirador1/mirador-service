<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclusion filter — intentional suppressions only.

  Rule of thumb: fix real bugs, document why false positives are excluded.
  Do NOT bulk-exclude entire categories.
-->
<FindBugsFilter>

    <!--
      EI_EXPOSE_REP2 — "may expose internal representation by storing a mutable object"

      SpotBugs flags every Spring bean injected via constructor as "dangerous" because
      an external caller could theoretically modify the stored reference.
      In a Spring IoC context this is a false positive:
        - Beans are managed singletons; no external code holds a reference after injection.
        - Making defensive copies (new ObservationRegistry(...)) would break the framework.
      Excluded globally for the project; revisit if non-Spring code is added.
    -->
    <Match>
        <Bug code="EI2"/>
    </Match>

    <!--
      CT_CONSTRUCTOR_THROW — "constructor throws exception, object may be partially initialized"

      JwtTokenProvider's constructor calls Keys.hmacShaKeyFor() which throws if the secret
      is too short. Spring treats this as a startup failure (fail-fast), so the partially
      constructed object is never accessible to external code. The "Finalizer attack" vector
      requires a subclass with a finalizer — impossible here since the class is a @Component.
    -->
    <Match>
        <Class name="com.mirador.auth.JwtTokenProvider"/>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>

    <!--
      EI_EXPOSE_REP — "may expose internal representation by returning a mutable object"

      SpotBugs flags Java records that contain List fields because the accessor
      returns the list directly. Records are immutable by design: the field is final
      and the accessor is generated by the compiler. The list content could technically
      be mutated, but these DTOs are serialized to JSON immediately — no caller modifies them.
    -->
    <Match>
        <Or>
            <Class name="com.mirador.customer.BatchImportResult"/>
            <Class name="com.mirador.customer.CursorPage"/>
        </Or>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>

    <!--
      REC_CATCH_EXCEPTION — "Exception caught but no exception is thrown in try block"

      TestReportInfoContributor deliberately catches broad Exception in XML parsing
      helpers to return gracefully instead of crashing the actuator. Safe to exclude.
    -->
    <Match>
        <Class name="com.mirador.observability.TestReportInfoContributor"/>
        <Bug pattern="REC_CATCH_EXCEPTION"/>
    </Match>


    <!--
      REC_CATCH_EXCEPTION — "Exception caught but no exception is thrown in try block"

      QualityReportEndpoint deliberately catches broad Exception in XML/JSON parsing
      helpers to return a graceful "available: false" map instead of throwing. The try
      blocks use DocumentBuilder.parse() and ObjectMapper.readTree() which declare
      checked exceptions (SAXException, IOException, ParserConfigurationException) but
      SpotBugs sees only the compiler-widened catch. Safe to exclude for this class.
    -->
    <Match>
        <Class name="com.mirador.observability.QualityReportEndpoint"/>
        <Bug pattern="REC_CATCH_EXCEPTION"/>
    </Match>

</FindBugsFilter>
