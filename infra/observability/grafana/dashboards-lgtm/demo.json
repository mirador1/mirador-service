    {
      "title": "🟢 Health",
      "description": "Calls GET /actuator/health — Spring Boot composite health (DB, Redis, disk, ping). UP only if ALL components are UP. Exact status from the actuator endpoint, not a proxy metric.",
      "type": "stat",
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "infinity"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 62
      },
      "targets": [
        {
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "infinity"
          },
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "dataframe",
          "url": "http://host.docker.internal:8080/actuator/health",
          "url_options": {
            "method": "GET",
            "data": ""
          },
          "root_selector": "",
          "columns": [
            {
              "selector": "status",
              "text": "status",
              "type": "string"
            }
          ],
          "filters": [],
          "global_query_id": ""
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "string",
          "mappings": [
            {
              "type": "value",
              "options": {
                "UP": {
                  "text": "UP",
                  "color": "green",
                  "index": 0
                }
              }
            },
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": {
                  "text": "DOWN",
                  "color": "red",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
