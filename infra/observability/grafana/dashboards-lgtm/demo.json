  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP requests rate",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_milliseconds_count[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
